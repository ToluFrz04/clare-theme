{% if section.settings.show_announcement %}
<div class="announcement-bar">
  {{ section.settings.announcement_text }}
</div>
{% endif %}

<header class="site-header" role="banner">
  <div class="header-inner">
    <nav class="header-nav" aria-label="Hauptnavigation">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>

    <a href="{{ routes.root_url }}" class="header-logo" aria-label="{{ shop.name }}">
      CLAR<span>É</span>
    </a>

    <div class="header-actions">
      {% if shop.customer_accounts_enabled %}
        <a href="{{ routes.account_url }}" aria-label="Konto">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg>
        </a>
      {% endif %}
      <a href="{{ routes.search_url }}" aria-label="Suche">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="11" cy="11" r="7"/><path d="m16.5 16.5 4 4"/></svg>
      </a>
      <a href="{{ routes.cart_url }}" aria-label="Warenkorb">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
        {% if cart.item_count > 0 %}
          <span class="cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_announcement",
      "label": "Ankündigungsleiste anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Ankündigungstext",
      "default": "✦ Kostenloser Versand ab 50€ · Schnelle Lieferung nach Deutschland ✦"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigationsmenü",
      "default": "main-menu"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Header"
    }
  ]
}
{% endschema %}
